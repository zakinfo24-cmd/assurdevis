# ── Email Configuration (Optional) ───────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
EXPORT_TO_EMAILS=

# ── Application ──────────────────────────────────────────────────────────
PORT=8000

