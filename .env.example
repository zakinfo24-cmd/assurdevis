# ── Groq API Keys ───────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_MODEL=llama-3.3-70b-versatile

# ── CORS Configuration ───────────────────────────────────────────────────
